{
  "buildCommand": "npm run build",
  "outputDirectory": "front-end/dist",
  "installCommand": "npm install && cd back-end && npm install && cd ../front-end && npm install",
  "functions": {
    "api/**/*.ts": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/front-end/dist/index.html"
    }
  ]
}
