{
  "buildCommand": "./build.sh",
  "outputDirectory": "front-end/dist",
  "functions": {
    "api/*.ts": {
      "includeFiles": "api/dist/**,api/generated/**,api/node_modules/**,api/prisma/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    }
  ]
}
