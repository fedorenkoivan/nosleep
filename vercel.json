{
  "version": 2,
  "buildCommand": "./build.sh",
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/front-end/dist/$1"
    }
  ],
  "outputDirectory": "front-end/dist"
}
