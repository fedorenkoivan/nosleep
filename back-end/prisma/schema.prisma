generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model indian_territories {
  gid        Int                      @id @default(autoincrement())
  name       String?                  @db.VarChar(40)
  county     String?                  @db.VarChar(50)
  gnis_id    String?                  @db.VarChar(9)
  aia_code   String?                  @db.VarChar(4)
  pop1990    Float?
  pop2000    Float?
  pop2010    Float?
  pop2020    Float?
  dos_ll     String?                  @db.VarChar(7)
  dosll_date DateTime?                @db.Date
  calc_sq_mi Decimal?                 @db.Decimal
  datemod    DateTime?                @db.Date
  shape_leng Decimal?                 @db.Decimal
  shape_area Decimal?                 @db.Decimal
  geom       Unsupported("geometry")?

  @@index([geom], type: Gist)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ny_cities {
  gid        Int                      @id @default(autoincrement())
  name       String?                  @db.VarChar(40)
  muni_type  String?                  @db.VarChar(4)
  munitycode Int?
  county     String?                  @db.VarChar(50)
  gnis_id    String?                  @db.VarChar(9)
  fips_code  String?                  @db.VarChar(10)
  swis       String?                  @db.VarChar(6)
  pop1990    Float?
  pop2000    Float?
  pop2010    Float?
  pop2020    Float?
  dos_ll     String?                  @db.VarChar(7)
  dosll_date DateTime?                @db.Date
  map_symbol String?                  @db.VarChar(1)
